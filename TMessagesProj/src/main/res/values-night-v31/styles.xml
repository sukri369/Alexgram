<resources
    xmlns:android="http://schemas.android.com/apk/res/android">
    <style name="Theme.TMessages.Start" parent="Theme.AppCompat.DayNight">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:actionBarStyle">@style/ActionBar.Transparent.TMessages.Start</item>
        <item name="android:colorBackground">#061B3D</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorPrimaryDark">#041430</item>
        <item name="android:colorPrimary">#061B3D</item>
        <item name="android:navigationBarColor">#041430</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowSplashScreenAnimationDuration">@integer/splash_screen_duration</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground">#061B3D</item>
    </style>
    <style name="ActionBar.Transparent.TMessages.Start" parent="android:style/Widget.Material.Light.ActionBar">
        <item name="android:background">#ff232d3a</item>
        <item name="android:textColor">#ffffff</item>
        <item name="android:logo">@drawable/transparent</item>
        <item name="android:title">""</item>
    </style>
</resources>
